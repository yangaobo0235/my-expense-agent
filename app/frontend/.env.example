VITE_API_BASE_URL=http://localhost:25101

# 使用 "keycloak" 走真实 Authorization Code + PKCE。
# 本地只调 UI、不接 Keycloak 时，可临时改为 "development"。
VITE_AUTH_MODE=keycloak

# 设置为 "msw" 时启用浏览器侧 Mock Service Worker。
# 真实后端联调和演示验收请留空。
VITE_MOCK_API=

VITE_KEYCLOAK_URL=http://192.168.23.66:18080
VITE_KEYCLOAK_REALM=expense-flow
VITE_KEYCLOAK_CLIENT_ID=expense-web

VITE_GRAFANA_URL=http://192.168.23.66:3000
VITE_LANGFUSE_URL=http://192.168.23.66:13000
