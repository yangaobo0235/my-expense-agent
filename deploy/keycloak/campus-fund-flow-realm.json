{
  "realm": "campus-fund-flow",
  "enabled": true,
  "displayName": "CampusFundFlow",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "roles": {
    "realm": [
      {"name": "STUDENT"},
      {"name": "ADVISOR"},
      {"name": "COLLEGE_REVIEWER"},
      {"name": "FINANCE_ADMIN"},
      {"name": "PROMPT_AUTHOR"},
      {"name": "PROMPT_REVIEWER"},
      {"name": "PROMPT_PUBLISHER"},
      {"name": "AUDITOR"}
    ]
  },
  "clients": [
    {
      "clientId": "campus-fund-web",
      "name": "CampusFundFlow Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:25105/*", "http://127.0.0.1:25105/*", "http://192.168.23.66:25105/*"],
      "webOrigins": ["http://localhost:25105", "http://127.0.0.1:25105", "http://192.168.23.66:25105"],
      "attributes": {"pkce.code.challenge.method": "S256"},
      "protocolMappers": [
        {
          "name": "campus-fund-backend-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "campus-fund-backend",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "campus-fund-backend",
      "name": "CampusFundFlow Backend",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocolMappers": [
        {
          "name": "campus-fund-backend-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "campus-fund-backend",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "account-mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "account-mcp",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "fund-reimbursement-mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "fund-reimbursement-mcp",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "audit-history-mcp-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "audit-history-mcp",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "account-mcp",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false
    },
    {
      "clientId": "fund-reimbursement-mcp",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false
    },
    {
      "clientId": "audit-history-mcp",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false
    }
  ]
}
